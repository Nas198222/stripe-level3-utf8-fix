includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 5
    paths:
        - src
    bootstrapFiles:
        - vendor/php-stubs/woocommerce-stubs/woocommerce-stubs.php
    # PHPDoc-derived types are often approximate (especially in WP/WC core).
    # Don't fail CI on narrowed-type inferences that only come from docblocks.
    treatPhpDocTypesAsCertain: false
    excludePaths:
        - vendor (?)
        - node_modules (?)
