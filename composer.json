{
    "name": "nas198222/stripe-level3-utf8-fix",
    "description": "WooCommerce Stripe Gateway Level3 UTF-8 truncation fix (mu-plugin) + health watchdog + full documentation.",
    "type": "wordpress-muplugin",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "php-stubs/woocommerce-stubs": "^9.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "analyse": "phpstan analyse --memory-limit=512M",
        "lint": "find . -name '*.php' -not -path './vendor/*' -exec php -l {} \\;"
    }
}
